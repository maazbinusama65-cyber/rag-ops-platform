{
  "title": "RAG-Ops Platform",
  "uid": "ragops-main",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Queries",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rag_queries_total)",
          "legendFormat": "Total"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] } } }
    },
    {
      "id": 2,
      "title": "Queries Per Hour",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(rag_queries_total[1h]))",
          "legendFormat": "Last 1h"
        }
      ],
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] } } }
    },
    {
      "id": 3,
      "title": "Error Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(rag_queries_total{status=\"error\"}[5m])) / sum(rate(rag_queries_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "percent", "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 4,
      "title": "Vectors in ChromaDB",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "targets": [
        { "expr": "chroma_vectors_total", "legendFormat": "Vectors" }
      ],
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": 0 }] } } }
    },
    {
      "id": 5,
      "title": "Average Retrieval Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(rag_retrieval_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 Retrieval (ms)"
        },
        {
          "expr": "histogram_quantile(0.50, rate(rag_retrieval_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50 Retrieval (ms)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 6,
      "title": "LLM Generation Latency (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(llm_generation_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p95 Generation (ms)"
        },
        {
          "expr": "histogram_quantile(0.50, rate(llm_generation_latency_seconds_bucket[5m])) * 1000",
          "legendFormat": "p50 Generation (ms)"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } } },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 7,
      "title": "Query Rate (req/min)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(rag_queries_total{status=\"success\"}[1m])) * 60",
          "legendFormat": "Successful queries/min"
        },
        {
          "expr": "sum(rate(rag_queries_total{status=\"error\"}[1m])) * 60",
          "legendFormat": "Failed queries/min"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } } }
    },
    {
      "id": 8,
      "title": "Active Requests",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        { "expr": "rag_active_requests", "legendFormat": "Active Requests" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" } } }
    }
  ]
}
