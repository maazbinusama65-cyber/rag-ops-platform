# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ragops
POSTGRES_USER=ragops
POSTGRES_PASSWORD=ragops_secret

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=runbooks
MINIO_SECURE=false

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=runbooks

# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# ── RAG settings ──────────────────────────────────────────────────────────────
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
